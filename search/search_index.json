<li>\u5b9a\u4e49\uff1a\u8ba9\u673a\u5668\u201c\u7406\u89e3\u201d\u8bed\u8a00\u542b\u4e49\u7684\u6280\u672f\u3002</li> <li>\u76ee\u6807\uff1a\u8bed\u4e49\u7406\u89e3\u3001\u610f\u56fe\u8bc6\u522b\u3001\u8bed\u5883\u63a8\u7406</li> <li>\u5c5e\u6027\uff1aNLP \u7684\u5b50\u9886\u57df</li> </ul>"},{"location":"%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD/%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E5%A4%84%E7%90%86%20%E3%80%81%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E7%90%86%E8%A7%A3%E7%AD%89/#3-nlg-natural-language-generation","title":"3\ufe0f\u20e3 \u81ea\u7136\u8bed\u8a00\u751f\u6210\uff08NLG, Natural Language Generation\uff09","text":"<ul> <li>\u5b9a\u4e49\uff1a\u8ba9\u673a\u5668\u201c\u751f\u6210\u201d\u81ea\u7136\u8bed\u8a00\u3002</li> <li>\u5e94\u7528\uff1a\u6587\u672c\u751f\u6210\u3001\u5bf9\u8bdd\u56de\u590d\u3001\u6458\u8981\u751f\u6210\u7b49</li> <li>\u5c5e\u6027\uff1aNLP \u7684\u53e6\u4e00\u5b50\u9886\u57df</li> </ul>"},{"location":"%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD/%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E5%A4%84%E7%90%86%20%E3%80%81%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E7%90%86%E8%A7%A3%E7%AD%89/#_3","title":"\u4e8c\u3001\u5c42\u7ea7\u7ed3\u6784\u56fe","text":"<pre><code>\u4eba\u5de5\u667a\u80fd\uff08AI\uff09\n  \u2514\u2500\u2500 \u673a\u5668\u5b66\u4e60\uff08ML\uff09\n        \u2514\u2500\u2500 \u6df1\u5ea6\u5b66\u4e60\uff08DL\uff09\n              \u2514\u2500\u2500 \u81ea\u7136\u8bed\u8a00\u5904\u7406\uff08NLP\uff09\n                    \u251c\u2500\u2500 \u81ea\u7136\u8bed\u8a00\u7406\u89e3\uff08NLU\uff09\n                    \u2514\u2500\u2500 \u81ea\u7136\u8bed\u8a00\u751f\u6210\uff08NLG\uff09\n</code></pre>"},{"location":"%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD/%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E5%A4%84%E7%90%86%20%E3%80%81%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E7%90%86%E8%A7%A3%E7%AD%89/#_4","title":"\u4e09\u3001\u6280\u672f\u80fd\u529b\u5bf9\u6bd4","text":"\u7ef4\u5ea6 NLP NLU NLG \u5b9a\u4f4d \u603b\u4f53\u7cfb \u7406\u89e3 \u751f\u6210 \u5173\u6ce8\u70b9 \u8bed\u8a00\