80%81%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E7%90%86%E8%A7%A3%E7%AD%89/#_6","title":"\u4e94\u3001\u73b0\u4ee3\u5927\u6a21\u578b\u4e2d\u7684\u5173\u7cfb","text":"<p>\u4ee5 OpenAI \u7684 GPT \u7cfb\u5217\u4e3a\u4f8b\uff1a</p> <ul> <li>\u5e95\u5c42\u5c5e\u4e8e NLP</li> <li>\u5177\u5907 NLU\uff08\u7406\u89e3\u95ee\u9898\uff09</li> <li>\u5177\u5907 NLG\uff08\u751f\u6210\u56de\u7b54\uff09</li> <li>\u57fa\u4e8e Transformer \u6df1\u5ea6\u5b66\u4e60\u67b6\u6784</li> </ul> <p>\u73b0\u4ee3\u5927\u6a21\u578b\u5df2\u7ecf\u5c06 NLU + NLG \u6df1\u5ea6\u878d\u5408\uff0c\u4e0d\u518d\u4e25\u683c\u533a\u5206\u6a21\u5757\u3002</p>"},{"location":"%E4%BA%BA%E5%B7%A5%E6%99%BA%E8%83%BD/%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E5%A4%84%E7%90%86%20%E3%80%81%E8%87%AA%E7%84%B6%E8%AF%AD%E8%A8%80%E7%90%86%E8%A7%A3%E7%AD%89/#_7","title":"\u516d\u3001\u4e00\u4e2a\u901a\u4fd7\u7c7b\u6bd4","text":"<p>\u628a NLP \u5f53\u6210\u201c\u8bed\u8a00\u80fd\u529b\u4f53\u7cfb\u201d\uff1a</p> <ul> <li>NLU = \u542c\u61c2\u522b\u4eba\u8bf4\u8bdd</li> <li>NLG = \u81ea\u5df1\u8868\u8fbe\u8bf4\u8bdd</li> <li>NLP = \u6574\u4e2a\u8bed\u8a00\u80fd\u529b\u7cfb\u7edf</li> </ul>"},{"location":"%E5%89%8D%E7%AB%AF%E5%BC%80%E5%8F%91/","title":"\u524d\u8a00","text":"<p>\u8bb0\u5f55\u524d\u7aef\u5f00\u53d1\u5b66\u4e60\u8fc7\u7a0b\u4e2d\u7684\u7b14\u8bb0</p>"},{"location":"%E7%88%AC%E8%99%AB/","title":"\u524d\u8a00","text":"<p>\u8bb0\u5f55\u4e00\u4e0b\u81ea\u5df1\u5b66\u4e60\u722c\u866b\u7684\u8fc7\u7a0b\uff0c\u5305\u62ec\u4e00\u4e9b\u722c\u866b\u7684\u6280\u5de7\uff0c\u4ee5\u53ca\u4e00\u4e9b\u722c\u866b\u7684\u6846\u67b6\u3002</p>"},{"location":"%E7%94%9F%E6%B4%BB%E8%AE%B0%E5%BD%95/","title":"\u524d\u8a00","text":"<p>\u8bb0\u5f55\u4e00\u4e9b\u751f\u6d3b\u4fe1\u606f\u3002</p>"}]}